  "files": [
    "lib",
    "assets",
    "test/util",
    "test/helper",
    "test/matchers",
    "!lib/**/*.spec.ts"
  ],
  "scripts": {
    "all": "run-s lint test generate-types",
    "lint": "eslint .",
    "dev": "npm test -- --auto-watch --no-single-run",
    "generate-types": "run-s generate-types:*",
    "generate-types:generate": "del-cli \"lib/**/*.d.ts\" \"lib/**/*.d.ts.map\" && npx bio-dts -r lib --declarationMap",
    "generate-types:test": "tsc --noEmit --noImplicitAny",
    "test": "karma start karma.conf.cjs",
    "prepublishOnly": "run-s generate-types"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bpmn-io/diagram-js"
  },
  "engines": {
    "node": "*"
  },
  "keywords": [
    "modeler",
    "modeling",
    "canvas",
    "diagram-js"
  ],
  "author": {
    "name": "Nico Rehwaldt",
    "url": "https://github.com/nikku"
  },
  "contributors": [
    {
      "name": "bpmn.io contributors",
      "url": "https://github.com/bpmn-io"
    }
  ],
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
